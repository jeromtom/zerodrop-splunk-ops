{
  "name": "zerodrop-dropwatch",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:local": "node scripts/local-db.mjs",
    "db:init": "node --env-file=.env.local scripts/init-table.mjs",
    "db:seed": "node --env-file=.env.local scripts/init-table.mjs && node --env-file=.env.local scripts/seed.mjs",
    "db:init:aws": "node scripts/init-table.mjs",
    "db:seed:aws": "node scripts/init-table.mjs && node scripts/seed.mjs",
    "ops:demo": "node --experimental-strip-types --import ./scripts/ts-resolve.mjs scripts/ops-demo.mts",
    "ops:test": "node --experimental-strip-types --import ./scripts/ts-resolve.mjs scripts/ops-test.mts",
    "ops:mcp": "node --experimental-strip-types --import ./scripts/ts-resolve.mjs scripts/ops-mcp-demo.mts",
    "mcp:server": "node --experimental-strip-types --import ./scripts/ts-resolve.mjs scripts/mcp-server.mts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1068.0",
    "@aws-sdk/lib-dynamodb": "^3.1068.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dynalite": "^4.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
