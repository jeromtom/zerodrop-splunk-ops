# ---- DynamoDB ---------------------------------------------------------
# Single table name (created by `npm run db:init`)
DDB_TABLE=zerodrop

# LOCAL DEV: point at the local emulator and you need no AWS account at all.
#   npm run db:local   (dynalite, no Docker)  — or —  docker compose up
DYNAMODB_ENDPOINT=http://localhost:8005

# PRODUCTION (Vercel): delete DYNAMODB_ENDPOINT and set these instead.
# (Vercel reserves the AWS_* variable names, hence the ZD_ prefix.)
# ZD_AWS_REGION=us-east-1
# ZD_AWS_ACCESS_KEY_ID=AKIA...
# ZD_AWS_SECRET_ACCESS_KEY=...

# ---- App ---------------------------------------------------------------
# Secret for signing session cookies. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# Password assigned to the seeded demo brand account (demo@zerodrop.app)
DEMO_PASSWORD=drop-zero-2026

# ====================================================================
#  DropWatch — Splunk agentic observability layer
#  EVERYTHING BELOW IS OPTIONAL. With none of it set, DropWatch runs in
#  MOCK MODE: telemetry no-ops to Splunk, the agent reads a local buffer,
#  and the rules engine reasons. `npm run ops:demo` works with zero keys.
# ====================================================================

# ---- Splunk HEC (telemetry ingestion: app -> Splunk) -----------------
# From Splunk: Settings > Data inputs > HTTP Event Collector > New Token.
# SPLUNK_HEC_URL=https://<your-stack>.splunkcloud.com:8088/services/collector
# SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
SPLUNK_INDEX=zerodrop
SPLUNK_METRICS_INDEX=zerodrop_metrics
# Self-signed trial cert? set to 1 to skip TLS verify (dev only).
# SPLUNK_HEC_INSECURE=1
# Set to 1 to console.log every telemetry event locally even without HEC.
# SPLUNK_HEC_DEBUG=1

# ---- Splunk MCP Server (agent reads telemetry back via MCP) -----------
# Preferred path — qualifies for "Best Use of Splunk MCP Server".
# See docs/SPLUNK_MCP.md for how to run the server + the tool contract.
# SPLUNK_MCP_URL=http://localhost:8050/mcp
# SPLUNK_MCP_TOKEN=...
# SPLUNK_MCP_TOOL=run_splunk_search

# ---- Splunk REST search API (fallback to MCP for reading telemetry) ---
# SPLUNK_API_URL=https://<your-stack>.splunkcloud.com:8089
# SPLUNK_API_TOKEN=...   (Settings > Tokens, a Bearer auth token)

# ---- LLM for the agent's reasoning (3-tier fallback) ------------------
# 1) Splunk Hosted Models (OpenAI-compatible chat/completions endpoint)
# SPLUNK_HOSTED_MODEL_URL=https://<host>/v1/chat/completions
# SPLUNK_HOSTED_MODEL_TOKEN=...
# SPLUNK_HOSTED_MODEL=splunk-llm
# 2) AI/ML API fallback (OpenAI-compatible). Already provisioned for this build.
# AIMLAPI_API_KEY=...
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini
# 3) If neither set -> deterministic rules engine (always works).
