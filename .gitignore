# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare (opennext) build artifacts
/.open-next/
/.wrangler/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# zerodrop
!.env.example
.dynalite-data/
zerodrop-splunk-ops/

# generated voiceover clips
audio/

# internal strategy / red-team notes (keep local, do not publish)
SELF_REVIEW.md
STRATEGY.md

# python bytecode
__pycache__/
*.pyc

# Cloudflare deploy scratch log
cf-deploy.log
